{"remainingRequest":"C:\\Users\\86187\\Downloads\\1223\\vue-idle-game\\node_modules\\babel-loader\\lib\\index.js!C:\\Users\\86187\\Downloads\\1223\\vue-idle-game\\node_modules\\cache-loader\\dist\\cjs.js??ref--0-0!C:\\Users\\86187\\Downloads\\1223\\vue-idle-game\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\86187\\Downloads\\1223\\vue-idle-game\\src\\views\\component\\strengthenEquipment.vue?vue&type=script&lang=js&","dependencies":[{"path":"C:\\Users\\86187\\Downloads\\1223\\vue-idle-game\\src\\views\\component\\strengthenEquipment.vue","mtime":1744374704364},{"path":"C:\\Users\\86187\\Downloads\\1223\\vue-idle-game\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1744375049567},{"path":"C:\\Users\\86187\\Downloads\\1223\\vue-idle-game\\node_modules\\babel-loader\\lib\\index.js","mtime":1744375049217},{"path":"C:\\Users\\86187\\Downloads\\1223\\vue-idle-game\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1744375049567},{"path":"C:\\Users\\86187\\Downloads\\1223\\vue-idle-game\\node_modules\\vue-loader\\lib\\index.js","mtime":1744375050312}],"contextDependencies":[],"result":["//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\nimport { assist } from \"../../assets/js/assist\";\nimport cTooltip from \"../uiComponent/tooltip\";\nimport handle from \"../../assets/js/handle\";\nexport default {\n  components: {\n    cTooltip: cTooltip\n  },\n  name: \"equimentPanel\",\n  mixins: [assist],\n  data: function data() {\n    return {\n      equiment: {},\n      strengTime: '',\n      //刷新副本计时器\n      strengTimeO: 60,\n      //刷新副本时间间隔 单位：S\n      autoStrengModel: false,\n      autoStrengLv: 12,\n      autoStrengTime: '',\n      recast: false,\n      qualityClass: '',\n      qualityProbability: [0.25, 0.55, 0.15, 0.05],\n      quality: [{\n        name: '破旧',\n        qualityCoefficient: 0.7,\n        probability: '0.25',\n        color: '#a1a1a1',\n        extraEntryNum: 1\n      }, {\n        name: '普通',\n        qualityCoefficient: 1,\n        probability: '0.55',\n        color: '#fff',\n        extraEntryNum: 2\n      }, {\n        name: '神器',\n        qualityCoefficient: 1.5,\n        probability: '0.15',\n        color: '#ff00ff',\n        extraEntryNum: 3\n      }, {\n        name: '史诗',\n        qualityCoefficient: 2,\n        probability: '0.05',\n        color: '#f78918',\n        extraEntryNum: 4\n      }]\n    };\n  },\n  mounted: function mounted() {\n    var _this = this;\n\n    this.strengTime = setInterval(function () {\n      _this.strengTimeO--;\n\n      if (_this.strengTimeO <= 0) {\n        clearInterval(_this.strengTime);\n        _this.strengTime = '';\n        _this.strengTimeO = 60;\n      }\n    }, 1000);\n  },\n  computed: {\n    userGold: function userGold() {\n      return this.$store.state.playerAttribute.GOLD;\n    },\n    item: function item() {\n      return this.$store.state.needStrengthenEquipment;\n    },\n    strengthenNeedGold: function strengthenNeedGold() {\n      var a = parseInt((parseInt(this.equiment.lv) + 1) * Math.pow(1.1, Math.pow(this.equiment.enchantlvl, 1.1)) * (10 + parseInt(this.equiment.lv) / 5)) + 100;\n      return a;\n    },\n    recastNeedGold: function recastNeedGold() {\n      var a = parseInt(parseInt(this.equiment.lv) * this.equiment.quality.qualityCoefficient * (200 + 10 * parseInt(this.equiment.lv)) / 4);\n      return a;\n    }\n  },\n  watch: {\n    item: function item() {\n      this.equiment = this.$deepCopy(this.item);\n\n      if (!this.equiment.enchantlvl) {\n        this.$set(this.equiment, 'enchantlvl', 0);\n      }\n    }\n  },\n  methods: {\n    changeRecastStatus: function changeRecastStatus(v, k, status) {\n      // 设置是否处于重置状态中\n      this.qualityClass = '';\n      v.recastStatus = status;\n      this.$set(this.equiment.extraEntry, k, v);\n    },\n    // 强化装备\n    startStreng: function startStreng(auto) {\n      if (this.strengTime && this.equiment.enchantlvl >= 12) {\n        this.$store.commit(\"set_sys_info\", {\n          msg: \"\\n          \\u5237\\u65B0\\u9875\\u9762\\u65F6\\u9700\\u8981\\u7B49\\u5F8560S\\u624D\\u80FD\\u5F3A\\u5316+12\\u4EE5\\u4E0A\\uFF0C\\u4ECD\\u9700\\u7B49\\u5F85\".concat(this.strengTimeO, \"\\u79D2\\u3002\\n        \"),\n          type: 'wrning'\n        });\n        this.autoStrengModel = false;\n        clearInterval(this.autoStrengTime);\n        return;\n      } // 自动强化需要金币倍率\n\n\n      var ra = auto ? 2 : 1;\n      var needGold = this.strengthenNeedGold * 1; //ra\n\n      if (this.$store.state.playerAttribute.GOLD < needGold) {\n        this.stopAutoStreng();\n        this.$store.commit(\"set_sys_info\", {\n          msg: \"\\n              \\u94B1\\u4E0D\\u591F\\u554A\\uFF0C\\u5F3A\\u5316\\u5565\\u5462\\u3002\\n            \",\n          type: \"warning\"\n        });\n        return;\n      }\n\n      var lv = this.equiment.enchantlvl;\n      var probabilityOfSuccess = 1;\n\n      if (lv <= 5) {\n        probabilityOfSuccess = 1;\n      } else if (lv == 6) {\n        probabilityOfSuccess = 0.8;\n      } else if (lv == 7) {\n        probabilityOfSuccess = 0.65;\n      } else if (lv == 8) {\n        probabilityOfSuccess = 0.45;\n      } else if (lv == 9) {\n        probabilityOfSuccess = 0.3;\n      } else {\n        probabilityOfSuccess = 0.2;\n      }\n\n      var r = Math.random();\n\n      if (r < probabilityOfSuccess) {\n        // 强化成功\n        lv++;\n      } else {\n        // 强化失败\n        if (lv >= 5) {\n          lv = lv - 1;\n        }\n      }\n\n      this.$store.commit(\"set_player_gold\", -parseInt(needGold));\n      this.changeTheEquimentByLv(lv);\n      this.changeTheEquiment();\n    },\n    startAutoStreng: function startAutoStreng() {\n      var _this2 = this;\n\n      this.autoStrengModel = true;\n      this.autoStrengTime = setInterval(function () {\n        _this2.startStreng(true);\n\n        if (_this2.equiment.enchantlvl == _this2.autoStrengLv) {\n          _this2.stopAutoStreng();\n\n          _this2.$store.commit(\"set_sys_info\", {\n            msg: \"\\n              \\u81EA\\u52A8\\u5F3A\\u5316\\u5B8C\\u6210\\u4E86\\uFF0C\\u53BB\\u770B\\u770B\\u4F60\\u7684\\u88C5\\u5907\\u5427\\u3002\\n            \",\n            type: \"win\"\n          });\n        }\n      }, 150);\n    },\n    stopAutoStreng: function stopAutoStreng() {\n      this.autoStrengModel = false;\n      clearInterval(this.autoStrengTime);\n    },\n    // 重铸装备\n    recastTheEquiment: function recastTheEquiment(v, k) {\n      if (this.$store.state.playerAttribute.GOLD < this.recastNeedGold) {\n        this.$store.commit(\"set_sys_info\", {\n          msg: \"\\n              \\u94B1\\u4E0D\\u591F\\u554A\\uFF0C\\u91CD\\u94F8\\u5565\\u5462\\u3002\\n            \",\n          type: \"warning\"\n        });\n        return;\n      }\n\n      var newEntry = handle.createRandomEntry(this.equiment.lv, this.equiment.quality.qualityCoefficient);\n      this.$set(this.equiment.extraEntry, k, newEntry);\n      this.$store.commit(\"set_player_gold\", -parseInt(this.recastNeedGold));\n      var a = parseInt(this.equiment.extraEntry[k].EntryLevel);\n\n      if (a < 25) {\n        this.qualityClass = 'D';\n      } else if (a < 50 && a >= 25) {\n        this.qualityClass = 'C';\n      } else if (a < 70 && a >= 50) {\n        this.qualityClass = 'B';\n      } else if (a < 90 && a >= 70) {\n        this.qualityClass = 'A';\n      } else {\n        this.qualityClass = 'S';\n      }\n\n      this.changeTheEquiment();\n    },\n    //根据强化等级变动装备\n    changeTheEquimentByLv: function changeTheEquimentByLv(lv) {\n      this.equiment.enchantlvl = lv;\n    },\n    //修改成功时保存这个装备\n    changeTheEquiment: function changeTheEquiment() {\n      var backpackPanel = this.findBrothersComponents(this, 'backpackPanel', false)[0];\n      var index = this.findComponentUpward(this, 'index');\n      index.saveGame(false);\n      this.equiment.locked = true;\n      this.$set(backpackPanel.grid, backpackPanel.currentItemIndex, this.$deepCopy(this.equiment));\n    }\n  }\n};",{"version":3,"sources":["strengthenEquipment.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA+EA,SAAA,MAAA;AACA,OAAA,QAAA;AACA,OAAA,MAAA;AACA,eAAA;AACA,EAAA,UAAA,EAAA;AAAA,IAAA,QAAA,EAAA;AAAA,GADA;AAEA,EAAA,IAAA,EAAA,eAFA;AAGA,EAAA,MAAA,EAAA,CAAA,MAAA,CAHA;AAIA,EAAA,IAJA,kBAIA;AACA,WAAA;AACA,MAAA,QAAA,EAAA,EADA;AAEA,MAAA,UAAA,EAAA,EAFA;AAEA;AACA,MAAA,WAAA,EAAA,EAHA;AAGA;AACA,MAAA,eAAA,EAAA,KAJA;AAKA,MAAA,YAAA,EAAA,EALA;AAMA,MAAA,cAAA,EAAA,EANA;AAOA,MAAA,MAAA,EAAA,KAPA;AAQA,MAAA,YAAA,EAAA,EARA;AASA,MAAA,kBAAA,EAAA,CAAA,IAAA,EAAA,IAAA,EAAA,IAAA,EAAA,IAAA,CATA;AAUA,MAAA,OAAA,EAAA,CAAA;AACA,QAAA,IAAA,EAAA,IADA;AAEA,QAAA,kBAAA,EAAA,GAFA;AAGA,QAAA,WAAA,EAAA,MAHA;AAIA,QAAA,KAAA,EAAA,SAJA;AAKA,QAAA,aAAA,EAAA;AALA,OAAA,EAMA;AACA,QAAA,IAAA,EAAA,IADA;AAEA,QAAA,kBAAA,EAAA,CAFA;AAGA,QAAA,WAAA,EAAA,MAHA;AAIA,QAAA,KAAA,EAAA,MAJA;AAIA,QAAA,aAAA,EAAA;AAJA,OANA,EAWA;AACA,QAAA,IAAA,EAAA,IADA;AAEA,QAAA,kBAAA,EAAA,GAFA;AAGA,QAAA,WAAA,EAAA,MAHA;AAIA,QAAA,KAAA,EAAA,SAJA;AAIA,QAAA,aAAA,EAAA;AAJA,OAXA,EAgBA;AACA,QAAA,IAAA,EAAA,IADA;AAEA,QAAA,kBAAA,EAAA,CAFA;AAGA,QAAA,WAAA,EAAA,MAHA;AAIA,QAAA,KAAA,EAAA,SAJA;AAIA,QAAA,aAAA,EAAA;AAJA,OAhBA;AAVA,KAAA;AAiCA,GAtCA;AAuCA,EAAA,OAvCA,qBAuCA;AAAA;;AACA,SAAA,UAAA,GAAA,WAAA,CAAA,YAAA;AACA,MAAA,KAAA,CAAA,WAAA;;AACA,UAAA,KAAA,CAAA,WAAA,IAAA,CAAA,EAAA;AACA,QAAA,aAAA,CAAA,KAAA,CAAA,UAAA,CAAA;AACA,QAAA,KAAA,CAAA,UAAA,GAAA,EAAA;AACA,QAAA,KAAA,CAAA,WAAA,GAAA,EAAA;AACA;AACA,KAPA,EAOA,IAPA,CAAA;AAQA,GAhDA;AAiDA,EAAA,QAAA,EAAA;AAEA,IAAA,QAFA,sBAEA;AAAA,aAAA,KAAA,MAAA,CAAA,KAAA,CAAA,eAAA,CAAA,IAAA;AAAA,KAFA;AAGA,IAAA,IAHA,kBAGA;AAAA,aAAA,KAAA,MAAA,CAAA,KAAA,CAAA,uBAAA;AAAA,KAHA;AAIA,IAAA,kBAJA,gCAIA;AACA,UAAA,CAAA,GAAA,QAAA,CAAA,CAAA,QAAA,CAAA,