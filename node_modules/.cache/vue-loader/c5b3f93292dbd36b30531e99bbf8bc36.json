y\">\r\n    <div class=\"story-content\">\r\n      <p>{{ currentStory }}</p>\r\n      <button @click=\"nextStory\">下一条</button>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'StoryOverlay',\r\n  data() {\r\n    return {\r\n      showStory: true,\r\n      storyIndex: 0,\r\n      stories: [\r\n        '这是第一个剧情',\r\n        '这是第二个剧情',\r\n        '这是第三个剧情',\r\n        '这是第四个剧情',\r\n        '这是第五个剧情'\r\n      ]\r\n    }\r\n  },\r\n  computed: {\r\n    currentStory() {\r\n      return this.stories[this.storyIndex]\r\n    }\r\n  },\r\n  methods: {\r\n    nextStory() {\r\n      if (this.storyIndex < this.stories.length - 1) {\r\n        this.storyIndex++\r\n      } else {\r\n        this.showStory = false\r\n        this.$emit('story-end')\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.story-overlay {\r\n  position: fixed;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  background-color: rgba(0, 0, 0, 0.9);\r\n  z-index: 9999;\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n}\r\n\r\n.story-content {\r\n  max-width: 80%;\r\n  text-align: center;\r\n  color: white;\r\n}\r\n\r\nbutton {\r\n  margin-top: 20px;\r\n  padding: 10px 20px;\r\n  background-color: #4CAF50;\r\n  color: white;\r\n  border: none;\r\n  border-radius: 5px;\r\n  cursor: pointer;\r\n}\r\n</style>"]}]}